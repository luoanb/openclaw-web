    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.9.0",
    "@tsconfig/svelte": "^5.0.8",
    "clsx": "^2.1.1",
    "svelte-check": "^4.4.6",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
